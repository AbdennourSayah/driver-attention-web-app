# Path to the RGB checkpoint (defaults to backend/weights/rgb.pth)
DREYEVE_RGB_WEIGHTS=backend/weights/rgb.pth

# Comma-separated CORS allow-list (Next.js dev server defaults included)
DREYEVE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Force a specific torch device (cpu | cuda | mps). Leave empty to auto-detect.
# DREYEVE_DEVICE=cuda

# Hard caps for uploads (bytes)
# DREYEVE_MAX_IMAGE_BYTES=20971520
# DREYEVE_MAX_VIDEO_BYTES=209715200
# DREYEVE_MAX_VIDEO_FRAMES=1500

# Inference cadence for /predict/video (run inference every N frames)
# DREYEVE_VIDEO_STRIDE=1
# DREYEVE_VIDEO_OVERLAY_ALPHA=0.5

# Public base URL prepended to video output URLs (when serving over a CDN /
# different origin than the API). Leave empty to keep relative URLs.
# DREYEVE_PUBLIC_BASE=https://api.example.com
